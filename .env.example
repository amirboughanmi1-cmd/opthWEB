# ── Supabase ──────────────────────────────────────────────────────────────
# Project Settings → API. NEXT_PUBLIC_SUPABASE_URL is the PROJECT URL
# (https://<ref>.supabase.co) — NOT a key. The anon key is safe to expose
# (gated by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — NEVER prefix with NEXT_PUBLIC_. Bypasses RLS; used by API
# routes (ImageKit upload-auth check, revalidation).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── ImageKit ──────────────────────────────────────────────────────────────
# Dashboard → Developer options. The URL endpoint and public key are safe to
# expose (used in the browser for image URLs + signed uploads).
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/YOUR_ID
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_...

# Server-only — signs uploads in /api/imagekit/auth. NEVER NEXT_PUBLIC_.
IMAGEKIT_PRIVATE_KEY=private_...

# ── Revalidation (optional) ───────────────────────────────────────────────
# Long random string for server-to-server calls to /api/revalidate.
# The admin dashboard authenticates with its Supabase session instead,
# so this is only needed for external triggers (e.g. curl, cron).
REVALIDATE_SECRET=generate-a-long-random-string
